# Required
AFDIAN_USER_ID=replace_with_your_user_id
AFDIAN_TOKEN=replace_with_your_token

# Afdian API pagination
AFDIAN_PER_PAGE=100
AFDIAN_MAX_PAGES=30

# OpenCollective (optional, comma separated)
OPENCOLLECTIVE_SLUGS=
OPENCOLLECTIVE_BASE_URL=https://opencollective.com
OPENCOLLECTIVE_OPTIONAL=true

# Output and sorting
OUTPUT_PATH=dist/sponsors.svg
SORT_BY=amount
SORT_ORDER=desc
LIMIT=120

# SVG layout
SVG_AVATAR_SIZE=60
SVG_GAP=10
SVG_PADDING=20
SVG_COLUMNS=10
SVG_BACKGROUND=#f7fafc
SVG_RADIUS=50%
